{
  "kind": "collectionType",
  "collectionName": "dealer_files",
  "info": {
    "singularName": "dealer-file",
    "pluralName": "dealer-files",
    "displayName": "dealer-file"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "type": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "price",
        "tech_catalog",
        "instruction"
      ]
    },
    "countryCode": {
      "type": "enumeration",
      "required": false,
      "enum": [
        "RU",
        "UZ",
        "KZ",
        "TJ",
        "KG",
        "AM",
        "BY",
        "AZ"
      ]
    },
    "file": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "description": {
      "type": "text"
    },
    "isActive": {
      "type": "boolean",
      "default": true
    },
    "collectionSlug": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "amber",
        "scandy",
        "elizabeth",
        "salvador",
        "pitti",
        "buongiorno"
      ]
    },
    "collectionTitle": {
      "type": "string"
    },
    "sortOrder": {
      "type": "integer"
    }
  }
}
