{
  "kind": "collectionType",
  "collectionName": "dealer_calendar_requests",
  "info": {
    "singularName": "dealer-calendar-request",
    "pluralName": "dealer-calendar-requests",
    "displayName": "Dealer Calendar Request"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "calendarEventTitle": {
      "type": "string",
      "required": true
    },
    "calendarEventDate": {
      "type": "string",
      "required": true
    },
    "dealerTitle": {
      "type": "string",
      "required": true
    },
    "dealerEmail": {
      "type": "email",
      "required": true
    },
    "dealerPhone": {
      "type": "string"
    },
    "dealerRef": {
      "type": "string"
    },
    "employees": {
      "type": "text",
      "required": true
    },
    "comment": {
      "type": "text"
    },
    "requestStatus": {
      "type": "enumeration",
      "enum": [
        "new",
        "processed",
        "approved",
        "rejected"
      ]
    },
    "calendarEventSlug": {
      "type": "string"
    },
    "dealerAccountLogin": {
      "type": "string"
    }
  }
}
