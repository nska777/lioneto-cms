{
  "kind": "collectionType",
  "collectionName": "dealer_products",
  "info": {
    "singularName": "dealer-product",
    "pluralName": "dealer-products",
    "displayName": "Dealer Product"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "article": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "color": {
      "type": "string"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "gallery": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "collection": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::dealer-collection.dealer-collection"
    },
    "category": {
      "type": "enumeration",
      "enum": [
        "bedroom",
        "living-room",
        "youth",
        "hallway",
        "tables-chairs",
        "addon"
      ]
    },
    "sortOrder": {
      "type": "integer"
    },
    "isActive": {
      "type": "boolean",
      "default": true
    },
    "priceRU": {
      "type": "integer"
    },
    "priceUZ": {
      "type": "integer"
    },
    "priceKZ": {
      "type": "integer"
    },
    "priceTJ": {
      "type": "integer"
    },
    "size": {
      "type": "string"
    },
    "material": {
      "type": "string"
    },
    "variants": {
      "type": "component",
      "component": "dealer.variant",
      "repeatable": true
    }
  }
}
